# ==============================================================================
# LEAKSHIELD AI - PLANTILLA DE VARIABLES DE ENTORNO (v0.2.0-beta)
# ==============================================================================
#
# Este archivo contiene las claves y configuraciones necesarias para ejecutar
# LeakShield AI en desarrollo local o para desplegarlo en producción (Vercel).
# Copie este archivo como '.env' y reemplace los valores correspondientes.
#
# IMPORTANT: Nunca suba su archivo '.env' real al control de versiones (Git).

# ------------------------------------------------------------------------------
# 1. CONFIGURACIÓN CLIENTE DE FIREBASE (Requerido para Auth y Firestore)
# ------------------------------------------------------------------------------
# Estos valores se obtienen al crear una aplicación web en la consola de Firebase.
VITE_FIREBASE_API_KEY=AIzaSyFakeKeyPlaceholder1234567890
VITE_FIREBASE_AUTH_DOMAIN=leakshield-ai.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=leakshield-ai
VITE_FIREBASE_STORAGE_BUCKET=leakshield-ai.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:1234567890abcdef

# ------------------------------------------------------------------------------
# 2. CLAVES DE DESARROLLO LOCAL (Opcional - Fallback híbrido para desarrollo)
# ------------------------------------------------------------------------------
# Si se definen estas variables en local, el frontend omitirá los proxies serverless
# y realizará consultas directas a los proveedores de servicios (Modo Híbrido Dev).
VITE_HIBP_API_KEY=
VITE_GEMINI_API_KEY=

# ------------------------------------------------------------------------------
# 3. CONFIGURACIÓN DEL SERVIDOR PROXY SERVERLESS (Requerido en Vercel)
# ------------------------------------------------------------------------------
# Estos valores se deben configurar como "Environment Variables" en el dashboard de Vercel.

# Claves de integración de APIs (Vercel Serverless Endpoints)
HIBP_API_KEY=your_hibp_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Control de Orígenes Permisivos (Hardening CORS)
# Lista de orígenes separados por comas autorizados a realizar peticiones a sus APIs.
ALLOWED_ORIGINS=https://leakshield-ai.vercel.app,http://localhost:5173

# Credenciales del SDK Firebase Admin (Verificación Criptográfica de Tokens)
# Utilizadas para validar firmas de sesión de los clientes de forma segura.
# NOTA: En la llave privada, reemplace los saltos de línea reales con '\n'.
FIREBASE_PROJECT_ID=leakshield-ai
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@leakshield-ai.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQ...\n-----END PRIVATE KEY-----\n"
